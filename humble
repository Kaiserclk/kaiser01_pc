#!/usr/bin/env python3
"""ROS2 Humble Docker Container Manager CLI"""

import argparse
import os
import shutil
import subprocess
import sys
from pathlib import Path


SCRIPT_DIR = Path(os.path.realpath(__file__)).parent.resolve()
COMPOSE_FILE = SCRIPT_DIR / "docker-compose.yml"


class Colors:
    RED = "\033[0;31m"
    GREEN = "\033[0;32m"
    YELLOW = "\033[1;33m"
    BLUE = "\033[0;34m"
    NC = "\033[0m"


def print_color(text, color):
    print(f"{getattr(Colors, color.upper(), '')}{text}{Colors.NC}")


def check_docker():
    if not shutil.which("docker"):
        print_color("Error: docker is not installed", "red")
        sys.exit(1)
    
    try:
        subprocess.run(["docker", "compose", "version"], capture_output=True, check=True)
        return ["docker", "compose"]
    except (subprocess.CalledProcessError, FileNotFoundError):
        if shutil.which("docker-compose"):
            return ["docker-compose"]
        else:
            print_color("Error: docker compose is not installed", "red")
            print_color("Install with: sudo apt install docker-compose-plugin", "yellow")
            sys.exit(1)


def run_compose(compose_cmd, *args):
    cmd = [*compose_cmd, "-f", str(COMPOSE_FILE), *args]
    try:
        result = subprocess.run(cmd, check=True)
        return result
    except subprocess.CalledProcessError as e:
        sys.exit(e.returncode)


def cmd_start(compose_cmd, args):
    print_color("Configuring X11 access for container...", "green")
    try:
        subprocess.run(["xhost", "+local:"], check=True, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    except (subprocess.CalledProcessError, FileNotFoundError):
        print_color("Warning: xhost command failed, GUI may not work properly", "yellow")
    
    print_color("Starting ROS2 Humble container...", "green")
    run_compose(compose_cmd, "up", "-d")
    print_color("Container started successfully", "green")


def cmd_stop(compose_cmd, args):
    print_color("Stopping ROS2 Humble container...", "yellow")
    run_compose(compose_cmd, "stop")
    print_color("Container stopped successfully", "green")


def cmd_restart(compose_cmd, args):
    print_color("Restarting ROS2 Humble container...", "yellow")
    run_compose(compose_cmd, "restart")
    print_color("Container restarted successfully", "green")


def cmd_status(compose_cmd, args):
    print_color("ROS2 Humble container status:", "blue")
    run_compose(compose_cmd, "ps")


def cmd_logs(compose_cmd, args):
    run_compose(compose_cmd, "logs", "-f")


def cmd_exec(compose_cmd, args):
    # Check if container is running
    try:
        result = subprocess.run(
            ["docker", "ps", "--filter", "name=ros2_humble", "--filter", "status=running", "-q"],
            capture_output=True, text=True, check=True
        )
        if not result.stdout.strip():
            print_color("Container is not running. Starting container first...", "yellow")
            cmd_start(compose_cmd, args)
            # Wait for container to be ready
            import time
            time.sleep(2)
    except subprocess.CalledProcessError:
        print_color("Warning: Could not check container status, attempting to start...", "yellow")
        cmd_start(compose_cmd, args)
        import time
        time.sleep(2)
    
    print_color("Entering ROS2 Humble container...", "green")
    cmd = ["docker", "exec", "-it", "-w", "/root", "ros2_humble", "bash"]
    try:
        subprocess.run(cmd, check=True)
    except subprocess.CalledProcessError as e:
        sys.exit(e.returncode)


def cmd_pull(compose_cmd, args):
    print_color("Pulling latest ROS2 Humble image...", "green")
    run_compose(compose_cmd, "pull")
    print_color("Image pulled successfully", "green")


def cmd_down(compose_cmd, args):
    print_color("Stopping and removing ROS2 Humble container...", "yellow")
    run_compose(compose_cmd, "down")
    print_color("Container removed successfully", "green")


def main():
    compose_cmd = check_docker()
    
    parser = argparse.ArgumentParser(
        description="ROS2 Humble Docker Container Manager",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Commands:
  start       Start the ROS2 Humble container
  stop        Stop the ROS2 Humble container
  restart     Restart the ROS2 Humble container
  status      Show container status
  logs        Show container logs
  exec        Enter the running container
  pull        Pull the latest image
  down        Stop and remove the container
        """
    )
    
    parser.add_argument(
        "command",
        choices=["start", "stop", "restart", "status", "logs", "exec", "pull", "down"],
        help="Command to execute"
    )
    
    args = parser.parse_args()
    
    commands = {
        "start": cmd_start,
        "stop": cmd_stop,
        "restart": cmd_restart,
        "status": cmd_status,
        "logs": cmd_logs,
        "exec": cmd_exec,
        "pull": cmd_pull,
        "down": cmd_down,
    }
    
    commands[args.command](compose_cmd, args)


if __name__ == "__main__":
    main()
